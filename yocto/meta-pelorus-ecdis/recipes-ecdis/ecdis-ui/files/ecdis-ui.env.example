# Copy to /etc/default/ecdis-ui on the target (or merge via systemd drop-in).
#
# WAYLAND_DISPLAY must match the Weston socket (often wayland-0 or wayland-1).

WAYLAND_DISPLAY=wayland-0

# Mandatory ENC cell path passed to ecdis-ui:

ECDUI_ENC_PATH=/usr/share/pelorus-ecdis/demo.enc.000

# GPL-3.0 source offer (Path A — shown in About / License):
# Install gpl-source-offer-ecdis-ui.tar.xz under /usr/share/doc/ecdis-ui/ when available.

ECDIS_SOURCE_OFFER_URI=file:///usr/share/doc/ecdis-ui/gpl-source-offer-ecdis-ui.tar.xz
